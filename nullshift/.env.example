# Nullshift monorepo — environment template.
# Copy to apps/<app>/.env.local for local dev (each Next app reads its own .env.local).
# NEVER commit a real .env.local. Only this .env.example is tracked.

# ── Supabase ─────────────────────────────────────────────
# Project Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key (Project Settings → API → service_role). SERVER ONLY — never expose.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Admin allowlist ──────────────────────────────────────
# Comma-separated emails allowed into the admin app. Create these users in
# Supabase → Authentication → Users (Add user → set a password).
ADMIN_EMAILS=louis@nullshift.com

# ── Site URLs (auth email links + cross-app redirects) ───
NEXT_PUBLIC_SITE_URL=https://nullshift.com

# ── Email notifications (Resend) ─────────────────────────
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=Nullshift <confirm@nullshift.com>
ENQUIRY_NOTIFY_EMAIL=louis@nullshift.com
ENQUIRY_FROM_EMAIL=Nullshift <onboarding@resend.dev>
RESEND_AUDIENCE_ID=

# ── Quiz funnel (/start) ─────────────────────────────────
FUNNEL_RESOURCE_URL=https://nullshift.co.uk/resources

# ── Booking (Cal.com) ────────────────────────────────────
# Your Cal.com link, e.g. "nullshift/discovery". When set, an inline booking
# embed appears on /book. Leave empty to use the account/brief booking flow only.
NEXT_PUBLIC_CAL_LINK=

# ── Stripe (billing + Connect platform fee) ──────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Connect platform client id (Phase 4) — for taking a 2% application fee.
STRIPE_CONNECT_CLIENT_ID=
