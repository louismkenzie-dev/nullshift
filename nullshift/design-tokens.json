{
  "$schema": "https://design-tokens.org",
  "name": "Nullshift Design System",
  "updated": "2026-06-22",
  "description": "Agentic-AI automation agency. Alternating cream/dark sections, single emerald accent, square corners, TASA Orbiter display + Roboto Mono labels. See BRAND.md for full guidelines.",

  "color": {
    "brand": {
      "emerald": {
        "value": "#10b981",
        "comment": "The only brand colour. Actions, focus, one highlighted word per headline."
      },
      "emeraldHover": { "value": "#34d399" },
      "emeraldPressed": { "value": "#059669" },
      "onEmerald": { "value": "#0A0B0F", "comment": "Text/icons on emerald fills" }
    },
    "signal": {
      "comment": "Status only — never decoration.",
      "success": { "value": "#2BE08C" },
      "warning": { "value": "#F5D547" },
      "info": { "value": "#3DD7E5" },
      "danger": { "value": "#FF3A5C" }
    },
    "theme": {
      "comment": "Marketing site alternates these two per section (CSS .k-dark / .k-cream). Canonical brand palette.",
      "dark": {
        "bg": "#0a0a0a",
        "fg": "#f4f4e8",
        "muted": "#9a9a90",
        "faint": "#6a6a62",
        "surface": "#141414",
        "border": "rgba(244,244,232,0.14)",
        "borderStrong": "rgba(244,244,232,0.28)"
      },
      "cream": {
        "bg": "#f4f4e8",
        "fg": "#0a0a0a",
        "muted": "#55554c",
        "faint": "#8a8a7e",
        "surface": "#ecece0",
        "border": "rgba(10,10,10,0.16)",
        "borderStrong": "rgba(10,10,10,0.32)"
      }
    },
    "app": {
      "comment": "Auth surfaces (admin/portal/funnel) — fixed dark 'Halo' tokens.",
      "bg": "#0A0B0F",
      "surface": "#14151C",
      "elevated": "#1E2029",
      "fg": "#F2F4F8",
      "muted": "#9AA0AE",
      "faint": "#5C6170",
      "border": "#2A2D38",
      "borderStrong": "#3A3D4A"
    },
    "logo": {
      "pillLight": "#D6D6D6",
      "pillEmerald": "#10b981"
    }
  },

  "typography": {
    "fontFamily": {
      "display": "TASA Orbiter",
      "sans": "TASA Orbiter",
      "mono": "Roboto Mono",
      "displayFallback": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "monoFallback": "'JetBrains Mono', ui-monospace, monospace"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "display": 700,
      "giantNumber": 800
    },
    "case": {
      "displayHeadings": "uppercase",
      "labelsEyebrowsNumbers": "uppercase",
      "bodyAndLeads": "sentence"
    },
    "tracking": {
      "display": "-0.03em",
      "cardTitle": "-0.02em",
      "body": "-0.005em",
      "lead": "-0.01em",
      "label": "0.1em",
      "tag": "0.06em"
    },
    "lineHeight": {
      "displayTight": 1.0,
      "display": 1.06,
      "giantNumber": 0.93,
      "body": 1.5,
      "lead": 1.5
    },
    "scale": {
      "comment": "Fluid clamp() values; px approximations in BRAND.md.",
      "hero": "clamp(2.5rem, 6.4vw, 4.7rem)",
      "xl": "clamp(2.4rem, 5.4vw, 3.9rem)",
      "lg": "clamp(2rem, 4.4vw, 3rem)",
      "md": "clamp(1.5rem, 2.8vw, 2rem)",
      "sm": "clamp(1.15rem, 1.7vw, 1.45rem)",
      "giantNumber": "clamp(2.4rem, 5vw, 9rem)",
      "lead": "1.0625rem",
      "body": "0.9375rem",
      "label": "0.72rem",
      "tag": "0.66rem"
    }
  },

  "space": {
    "base": "4px",
    "scale": [4, 8, 12, 16, 20, 24, 32, 40, 48, 64, 80],
    "containerMax": "1280px",
    "containerWide": "1400px",
    "containerNarrow": "880px",
    "containerPadInline": "clamp(20px, 4vw, 40px)",
    "sectionPad": {
      "sm": "clamp(40px, 6vw, 72px)",
      "md": "clamp(64px, 8vw, 104px)",
      "lg": "clamp(88px, 11vw, 140px)"
    }
  },

  "radius": {
    "comment": "Square everywhere. Only true circles use full.",
    "none": "0",
    "sm": "0",
    "md": "0",
    "lg": "0",
    "xl": "0",
    "full": "999px"
  },

  "border": {
    "hairline": "1px"
  },

  "motion": {
    "ease": "cubic-bezier(0.2, 0.6, 0.2, 1)",
    "easeReveal": "cubic-bezier(0.16, 1, 0.3, 1)",
    "duration": { "fast": "120ms", "base": "150ms", "slow": "240ms" },
    "reveal": {
      "transform": "fade + blur(12px→0) + rise + scale(0.965→1)",
      "duration": "0.7–0.95s",
      "once": true
    },
    "smoothScroll": "Lenis",
    "reducedMotion": "honour prefers-reduced-motion everywhere"
  },

  "shadow": {
    "comment": "Avoid on marketing; used only on few floating cards / app modals.",
    "md": "0 8px 24px rgba(0,0,0,0.45), 0 1px 0 rgba(255,255,255,0.03) inset",
    "lg": "0 24px 60px rgba(0,0,0,0.55), 0 1px 0 rgba(255,255,255,0.04) inset",
    "focus": "0 0 0 3px rgba(16,185,129,0.30)"
  }
}
